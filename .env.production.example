# Production environment for docker-compose.prod.yml
#
# Copy to `.env` ON THE SERVER and fill in real values. Do NOT copy your local
# development .env up: it still carries unused AZURE_* and KAFKA_* credentials
# from the pre-pivot architecture (see docs/old-architecture/). Shipping those
# to a public box is live-credential exposure for zero benefit — the current app
# reads none of them.
#
# This file lists every variable the app actually reads. Anything not here is
# either unused or has a safe default in config.py.

# ── Environment ───────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Secrets (REQUIRED) ────────────────────────────────────────────────
# config.py RAISES on startup in production if these are missing or left at
# their default values, so the app cannot boot half-configured.
# Generate each with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
JWT_SECRET_KEY=
# Access-token lifetime. Long by design: a field reporter is often offline and
# cannot re-login mid-report (the JWT is only a turnstile — ADR-0016).
JWT_ACCESS_TOKEN_EXPIRES_DAYS=30

# ── Database ──────────────────────────────────────────────────────────
# Consumed by both the postgres container and the API's DATABASE_URL.
# Use a strong DB_PASSWORD: the default is "admin".
DB_USER=admin
DB_PASSWORD=
DB_NAME=melonews_prod

# ── Object storage — Hetzner, Falkenstein (ADR-0017) ──────────────────
# Media is uploaded/read DIRECTLY by clients via presigned URLs; the server
# never proxies media bytes (ADR-0009). Bucket must stay PRIVATE.
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ADDRESSING_STYLE=virtual
# TTL for the short-lived presigned GET URLs handed to readers.
MEDIA_READ_URL_TTL_MINUTES=60
# Optional: only set if serving objects through a CDN/custom domain.
# S3_PUBLIC_BASE_URL=

# ── Event clustering / corroboration thresholds ───────────────────────
# Tunable so they can be calibrated against real corroboration density during
# the pilot. Defaults shown; omit to accept them.
EVENT_CLUSTER_RADIUS_KM=1.0
EVENT_CLUSTER_WINDOW_HOURS=24
EVENT_CORROBORATION_THRESHOLD=2

# ── Anonymous ingest ──────────────────────────────────────────────────
# DISABLED for the pilot (ADR-0007): an unauthenticated public ingest is the
# easiest Sybil/spam vector and anonymous reports count 0 toward corroboration.
# Re-enable ONLY with real anti-abuse (device attestation / proof-of-work).
ANONYMOUS_INGEST_ENABLED=false
