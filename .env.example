# Production Environment Variables
# Copy this to .env on your DigitalOcean server
# DO NOT commit this file to GitHub

## Application Settings
ENVIRONMENT=production
FLASK_ENV=production
FLASK_APP=main.py
DEBUG=False

## Database Configuration
DB_USER=admin
DB_PASSWORD=your_secure_password_here
DB_HOST=melo-database
DB_PORT=5432
DB_NAME=melonews_prod
DATABASE_URL=postgresql://admin:your_secure_password_here@melo-database:5432/melonews_prod

## Azure Storage (for file uploads)
AZURE_STORAGE_ACCOUNT_NAME=your_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_account_key
AZURE_STORAGE_CONTAINER_NAME=melonews
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

## Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=eyesonpalestine
KAFKA_GROUP_ID=melo-consumer-prod

## JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_here_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

## API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_WORKERS=4

## Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

## Email Configuration (if applicable)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

## Scheduler Configuration
SCHEDULER_ENABLED=True
SCHEDULER_INTERVAL_MINUTES=60

## Redis (optional, for caching)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

## Security
ALLOWED_ORIGINS=https://melonews.io,https://www.melonews.io
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict

## Slack Webhook (for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

## DigitalOcean Spaces (optional S3-compatible storage)
DO_SPACE_NAME=melo-space
DO_SPACE_REGION=nyc3
DO_SPACE_ACCESS_KEY=your_access_key
DO_SPACE_SECRET_KEY=your_secret_key
DO_SPACE_CDN_ENDPOINT=https://melo-space.nyc3.cdn.digitaloceanspaces.com
