<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/colorBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="24sp"
        android:textColor="@color/colorPrimary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtLandingSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="How would you like to report?"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Anonymous block: button + caption + divider, grouped so a single
         visibility toggle hides the whole option cleanly. Gated on
         BuildConfig.ANONYMOUS_ENABLED — the server returns 403 for
         /anonymous-ingest unless ANONYMOUS_INGEST_ENABLED is set (ADR-0007),
         and a control that silently discards someone's report is a worse
         failure than no control at all. -->
    <LinearLayout
        android:id="@+id/anonymousBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Primary: Submit Anonymously -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnonymous"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit Anonymously"
            android:textSize="16sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No account, no history. The safest option in a hostile environment."
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Divider -->
        <View
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

    <!-- Secondary: Sign In -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSignIn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sign in to your account"
        android:textSize="14sp"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit and track your past submissions, work offline."
        android:textSize="12sp"
        android:textColor="#666666"
        android:gravity="center" />

</LinearLayout>
