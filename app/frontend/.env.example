# API base URL — use /api for dev (proxied by setupProxy.js), or an absolute URL for production
REACT_APP_API_URL=/api

# Dev proxy target (only used by setupProxy.js during local development)
# REACT_APP_PROXY_TARGET=http://127.0.0.1:5000

# Auto-enable low-bandwidth mode when connection downlink is below this Mbps threshold
REACT_APP_LOW_BANDWIDTH_THRESHOLD_MBPS=2

# Tier strategy thresholds and adaptive media caps
REACT_APP_CRITICAL_BANDWIDTH_THRESHOLD_MBPS=0.25
REACT_APP_MAX_VIDEO_MB_CRITICAL=8
REACT_APP_MAX_IMAGE_MB_CRITICAL=2
REACT_APP_MAX_VIDEO_MB_CONSTRAINED=25

# WebSocket dev server settings
WDS_SOCKET_HOST=127.0.0.1
WDS_SOCKET_PORT=3000

# Disable source maps in production builds
GENERATE_SOURCEMAP=false
