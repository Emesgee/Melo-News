# 3.12, not 3.9: the codebase uses PEP 604 unions (`str | None`, e.g.
# app/file_upload/media_sanitizer.py), which are a SyntaxError-at-import on
# <3.10 — the API crash-looped on 3.9 with "unsupported operand type(s) for |".
# 3.9 is also past end-of-security-support (Oct 2025). 3.12 is chosen over
# 3.13/3.14 because every pinned dependency (numpy 1.26, eventlet, opencv,
# psycopg2-binary) has mature 3.12 wheels.
FROM python:3.12-slim

WORKDIR /app

# Build deps for any native wheels, and curl for the container healthcheck
RUN apt-get update && \
	apt-get install -y --no-install-recommends build-essential gcc python3-dev libffi-dev curl && \
	rm -rf /var/lib/apt/lists/*

# Keep packaging tools current so we prefer prebuilt wheels
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

COPY requirements.txt .
RUN pip install --no-cache-dir --prefer-binary --only-binary=:all: -r requirements.txt

COPY . .

EXPOSE 5000

# Production WSGI server. `python main.py` runs Flask/SocketIO's DEV server —
# main.py prints a warning about exactly this. The app registers SocketIO
# handlers, so gunicorn needs an async worker; eventlet is already pinned in
# requirements.txt.
#
# -w 1 is required: Flask-SocketIO cannot span multiple workers without a
# message queue to share connection state between them.
#
# main:app works because main.py builds `app = create_app()` at module scope and
# runs db.create_all() on import, so schema setup happens when gunicorn loads it.
CMD ["gunicorn", "--worker-class", "eventlet", "-w", "1", \
     "--bind", "0.0.0.0:5000", "--timeout", "120", \
     "--access-logfile", "-", "--error-logfile", "-", \
     "main:app"]
